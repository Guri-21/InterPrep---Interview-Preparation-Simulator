# ─── InterPrep Backend — Environment Variables ───────────────────
# Copy this file to `.env` (or .env.local) and fill in real values.

# ── Server ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── MongoDB ──────────────────────────────────────────────────────
# Local:  mongodb://127.0.0.1:27017/interprep
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/interprep?retryWrites=true&w=majority&appName=InterPrep
MONGO_URI=mongodb://127.0.0.1:27017/interprep

# ── JWT ──────────────────────────────────────────────────────────
# Generate a strong secret with:  openssl rand -hex 64
JWT_SECRET=replace_with_a_long_random_string_at_least_64_chars
JWT_EXPIRE=7d

# ── Bcrypt ───────────────────────────────────────────────────────
BCRYPT_ROUNDS=10

# ── CORS ─────────────────────────────────────────────────────────
# Frontend origin(s). Comma-separated for multiple. Use the Vercel URL in prod.
CLIENT_URL=http://localhost:3000

# ── AI Provider ──────────────────────────────────────────────────
# Choose one of: "gemini" (free tier, default), "anthropic", "openai" (stub).
AI_PROVIDER=gemini

# ── Google Gemini  (FREE TIER — recommended)  ────────────────────
# Get a key at:  https://aistudio.google.com/app/apikey
# Free tier (as of 2026):  gemini-2.5-flash → 15 req/min, 1500 req/day.
# Other free-tier models: gemini-2.0-flash, gemini-1.5-flash.
GEMINI_API_KEY=AIzaSy_paste_your_gemini_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Anthropic Claude  (paid — only if AI_PROVIDER=anthropic)  ────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── OpenAI  (stubbed, not implemented yet) ───────────────────────
OPENAI_API_KEY=

# ── Bootstrap admin (used by `npm run seed:admin`) ───────────────
ADMIN_EMAIL=admin@interprep.local
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Platform Admin
