    "express-rate-limit": "^7.4.1",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.2",
    "morgan": "^1.10.0",
    "zod": "^3.23.8"
  },
  "engines": {
    "node": ">=18.18.0"
  },
