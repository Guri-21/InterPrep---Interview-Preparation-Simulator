{
  "name": "interprep-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "InterPrep backend — Express + MongoDB + JWT REST API for the InterPrep interview simulator.",
  "main": "server.js",
  "scripts": {
