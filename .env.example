# ─── InterPrep frontend — Environment Variables ──────────────────
# Copy this file to `.env.local` (Vite picks it up automatically) and fill
# in real values. NEVER commit .env.local.
#
# NOTE: Backend env vars (MONGO_URI, JWT_SECRET, ANTHROPIC_API_KEY, etc.)
# live in `backend/.env` — see `backend/.env.example`.

# Public display name shown in the navbar and document title.
VITE_APP_NAME="InterPrep"

# Optional. When deploying frontend and backend separately, set this to the
# fully-qualified API origin (e.g. "https://api.interprep.app"). Leave EMPTY
# when the frontend is served behind the same domain as /api.
VITE_API_BASE_URL=

# Dev-only: where Vite should proxy /api during `npm run dev`. Defaults
# to "http://localhost:4000" — the InterPrep Express backend.
VITE_DEV_API_PROXY="http://localhost:4000"
